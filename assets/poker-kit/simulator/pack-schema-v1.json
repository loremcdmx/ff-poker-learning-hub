{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.ff/poker-simulator/pack-schema-v1.json",
  "title": "Poker Simulator Pack v1",
  "type": "object",
  "required": ["schemaVersion", "name", "stackDepths", "spots"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "stackDepths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "number",
        "exclusiveMinimum": 0
      }
    },
    "playableWeight": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "policy": {
      "type": "object",
      "properties": {
        "preflopChart": { "type": "string" },
        "postflopModel": { "type": "string" },
        "scoring": { "type": "string" }
      },
      "additionalProperties": true
    },
    "spots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["heroPosition", "villainPosition", "prompt"],
        "properties": {
          "title": { "type": "string" },
          "heroPosition": { "type": "string" },
          "villainPosition": { "type": "string" },
          "startStreet": {
            "enum": ["preflop", "flop", "turn", "river"]
          },
          "boardCards": {
            "type": "array",
            "maxItems": 5,
            "items": { "type": "string" }
          },
          "pot": { "type": "number" },
          "toCall": { "type": "number" },
          "branch": {
            "type": "array",
            "items": { "type": "string" }
          },
          "prompt": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
